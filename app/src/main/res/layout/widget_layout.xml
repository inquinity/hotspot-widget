<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:drawable/dialog_frame"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Hotspot Status Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/hotspot_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@string/hotspot_status"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/hotspot_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/hotspot_off"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="4dp"
        android:background="@android:color/darker_gray" />

    <!-- Battery Status Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/battery_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@string/battery_status"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/battery_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="100%"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
